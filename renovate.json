{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "constraints": {
    "node": ">=22.13.0"
  },
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch",
      "matchPackageNames": [
        "*"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    }
  ],
  "labels": ["dependencies"],
  "assignees": ["danielrivers"]
}
