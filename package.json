    "eslint": "^10.0.0",
    "globals": "^17.0.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.3.3",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.0.3",
    "vitest": "^4.0.3",
    "vitest-fetch-mock": "^0.4.1"
  },
  "peerDependencies": {
    "expo-secure-store": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "expo-secure-store": {
      "optional": true
    }
  },
